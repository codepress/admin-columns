{
    "autoload": {
        "psr-4": {
            "AC\\": "classes/"
        }
    },
    "config": {
        "autoloader-suffix": "AdminColumns",
        "platform": {
            "php": "7.4.33"
        }
    },
    "require": {
        "php-di/php-di": "^6.4"
    },
    "scripts": {
        "prefix": [
            "@composer install --working-dir=build --no-interaction",
            "@php build/app.php prefix"
        ],
        "post-install-cmd": [
            "@prefix"
        ],
        "post-update-cmd": [
            "@prefix"
        ]
    }
}