{
    "autoload": {
        "psr-4": {
            "AC\\": "classes/"
        }
    },
    "config": {
        "autoloader-suffix": "AdminColumns",
        "platform": {
            "php": "7.4.33"
        }
    },
    "require": {
        "php-di/php-di": "^6.3.5"
    },
    "scripts": {
        "post-update-cmd": [
            "@php ../build/app.php prefix"
        ],
        "cs": "php-cs-fixer fix",
        "cs:check": "php-cs-fixer fix --dry-run --diff"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0"
    }
}